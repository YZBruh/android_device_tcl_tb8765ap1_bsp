#!/sbin/sh
#tb8765ap1_bsp data decrypt script by @YZ-Bruh
#Logcat temizliği
clear
echo "tb8765ap1_bsp veri şifreliyicisi by @YZ-Bruh"
echo "Şifreleme durumu kontrol ediliyor..."
#Mevcut dizin
current_dir=$(pwd)
#Vendor bölümüne erişim.
access_vendor=$(cd /vendor/etc)
  if [ ! -f "$access_vendor" ]; then
  echo "Vendor bölümüne erişilirken bir hata oluştu!";
  cd $current_dir
  exit;
fi;
  #Şifreleme durumu kontrolü
  crypto_stat_check=$(grep "encryptable" fstab.mt8765)
case $crypto_stat_check in
  encryptable)
  echo "Şifrelemenin devre dışı olduğu doğrulandı.";
esac;
  if [ ! -f "$crypto_stat_check" ]; then
  echo "Cihaz zaten şifrelenmiş!";
  cd $current_dir
  exit;
    fi;
  echo "Şifreleniyor..."
  #fstab.mt8765 düzenleniyor
  encrypt_vendor_mt_one=$(sed -i 's/encryptable/forcefdeorfbe/g' fstab.mt8765)
    if [ ! -f "$encrypt_vendor_mt_one" ]; then
  echo "fstab.mt8765 düzenlenirken bir hata oluştu!";
  cd $current_dir
  exit;
    fi;
    #fstab.mt6739 düzenleniyor
    encrypt_vendor_mt_two=$(sed -i 's/encryptable/forcefdeorfbe/g' fstab.mt6739)
      if [ ! -f "$decrypt_vendor_mt_two" ]; then
  echo "fstab.mt6739 düzenlenirken bir hata oluştu!";
  cd $current_dir
  exit;
      fi;
      #NVDATA erişimi.
      access_vnd_nvdata=$(cd /vendor/nvdata)
        if [ ! -f "$access_vnd_nvdata" ]; then
  echo "/vendor/nvdata erişimi sırasında bir sorun oluştu!";
  cd $current_dir
  exit;
      fi;
        #NVDATA düzenlemesi
      encrypt_nvdata_mt=$(sed -i 's/encryptable/forcefdeorfbe/g' fstab.mt8765)
        if [ ! -f "$decrypt_nvdata_mt" ]; then
  echo "NVDATA konumundaki fstab.mt8765 düzenlenirken bir hata oluştu!";
  cd $current_dir
  exit;
        fi;
        echo "Şifreleme yapıları uygulandı."
        echo "Cihazın veri biçimini EXT4 olarak yeniden biçimlendirin."
        echo "Eğer biçinlendirme yapmazsanız şifrelenmez."
        echo "Talimatlar: TWRP>Temizlik>Gelişmiş temizlik>Dosya sistemini onar veya değiştir>Veri>EXT4 ve kaydırın."
        echo "Sonra Dalvik/ART önbelleğini ve önbelleği temizleyin. Ve bitti!"
        #By @YZ-Bruh
        unset current_dir
        unset access_vendor
        unset crypto_stat_check
        unset encrypt_nvdata_mt
        unset encrypt_vendor_mt_one
        unset encrypt_vendor_mt_two
        unset access_vnd_nvdata
        exit;